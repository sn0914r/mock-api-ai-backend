{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "Node16",
    "moduleResolution": "Node16",

    "target": "ESNext",

    "lib": ["esnext"],
    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true
  }
}